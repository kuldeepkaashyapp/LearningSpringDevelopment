<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">


<bean class="com.springLearn.concepts.constructorInjection.PaymentService" name="paymentMethod" >

    <constructor-arg value="online"/>

</bean>

   <bean class="com.springLearn.concepts.constructorInjection.Orders" name="oders">
       <constructor-arg value="1110220" />
       <constructor-arg name="paymentService" ref="paymentMethod" />
   </bean>

</beans>